es":"28","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"e0yc4b",{"filePath":"29","messages":"30","suppressedMessages":"31","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"32","messages":"33","suppressedMessages":"34","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","suppressedMessages":"40","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"41","messages":"42","suppressedMessages":"43","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"44","messages":"45","suppressedMessages":"46","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"47"},{"filePath":"48","messages":"49","suppressedMessages":"50","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"51","messages":"52","suppressedMessages":"53","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"54","messages":"55","suppressedMessages":"56","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"57","messages":"58","suppressedMessages":"59","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"60","messages":"61","suppressedMessages":"62","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"63"},"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/index.js",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/App.js",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/layout/Header.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/HomePage/Home.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/MovieItems/Movie.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/SearchItem/Search.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/layout/Footer.jsx",[],[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/utils/fetchApi.js",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/MovieCategory/Popular.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/MovieCategory/TopRated.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/MovieCategory/Upcoming.jsx",[],[],"/Users/prasad/Documents/My-Projects/M-Flix/m-flix-app/src/componets/MovieCategory/Genres.jsx",["64"],[],"import React, { useEffect, useState } from 'react'\nimport { Img_URL, fetchGenreList, fetchGenresList } from '../../utils/fetchApi';\nimport { Link } from 'react-router-dom';\nimport { useQuery } from '@tanstack/react-query';\nimport  '../MovieCategory/genres.scss'\n\nconst Genres = () => {\n  const[genreId,setGenreId]=useState('28');\n  const [page,setPage]=useState(1);\n  const [GenresList,setGenresList]=useState([])\n \n  const loadMoreHandle=()=>{\n   setPage((prev)=> {\n    console.log(prev)\n    return prev=prev + 1;\n   });\n   setGenresList((prev)=> [...prev,...GenreList]);\n   refetch();\n }\n const selectGenreHandler =(e)=>{\n  setGenreId(e.target.value); \n  setGenresList(GenreList); \n  setPage(1);\n }\n\n  const { isLoading,isError,error ,data: GenreList,refetch} = useQuery({\n      queryKey: [\"GenreList\"],\n      queryFn: () =>\n        fetchGenreList(`${genreId}`,`${page}`).then((res) => {\n          if(page===1){\n            setGenresList(res.results);\n            setPage(2);\n          }\n          console.log(res.results);\n          return res.results;\n        }),\n    });\n\n    const {data:genre}=useQuery({\n      queryKey:['genre'],\n      queryFn:()=> fetchGenresList().then((res)=>\n      {\n        return res.genres;\n      }),\n    });\n   \n\n    useEffect(()=>{\n      refetch();\n      console.log(page);\n    },[refetch,page,genreId]);\n\n    if (isLoading) {\n      return (\n        <div className=\"loading\">\n          <h1>Loading...</h1>\n        </div>\n      );\n    } else if (isError) {\n      return (\n        <div className=\"error\">\n          <p>{error.message}</p>\n        </div>\n      );\n    } else\nreturn (\n  <section className='genre-body'>\n    <h1>Select your genre</h1>\n  <div className=\"genre-container\">\n        <aside  className=\"genre-list\">\n        {\n            genre?.map((item)=>(\n              <button key={item.id} value={item.id} onClick={(e)=>{ selectGenreHandler(e)}}\n              style={{background: genreId==item.id ?'red':'black'}}>{item.name}</button>\n            ))\n          } \n          </aside>\n        <div>\n        {GenresList?.map((item,index) => (\n           item.poster_path!==null &&\n            <Link to={`/movie/${item.id}`} className=\"card\" key={index}>\n              <img src={`${Img_URL}${item.poster_path}`} alt=\"img\" />\n            </Link>\n        ))}\n        <div>\n        </div>\n        </div>\n      </div>\n        <button onClick={loadMoreHandle}>More</button>\n      </section>\n)\n}\n\nexport default Genres\n",{"ruleId":"65","severity":1,"message":"66","line":74,"column":42,"nodeType":"67","messageId":"68","endLine":74,"endColumn":44},"eqeqeq","Expected '===' and instead saw '=='.","BinaryExpression","unexpected"]